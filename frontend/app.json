{
  "expo": {
    "name": "EventSpace",
    "slug": "eventspace",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#6C5CE7"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true
      }
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#6C5CE7" }
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "EventSpace accesses your photos to upload venue and equipment images."
        }
      ]
    ],
    "extra": {
      "API_URL": "http://192.168.1.2:5000/api"
    }
  }
}
